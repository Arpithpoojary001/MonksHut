      "name": "Login API",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsondata=pm.response.json()\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "\tpm.response.to.have.status(200);\r",
              "});\r",
              "pm.environment.set(\"token\", jsondata.accessToken)\r",
              "\r",
              "console.log(pm.environment.get(\"token\"))"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"emilys\",\r\n    \"password\": \"emilyspass\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
